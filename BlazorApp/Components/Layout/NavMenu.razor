@implements IDisposable
@inject NavigationManager NavigationManager

<nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm sticky-top px-4">
    <div class="container-fluid">

        <a class="navbar-brand fw-bold" href="">
            <i class="bi bi-rocket-takeoff-fill me-2"></i>Речевик
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#topNavbar">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="topNavbar">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item">
                    <NavLink class="nav-link" href="" Match="NavLinkMatch.All">Главная</NavLink>
                </li>

                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" id="contentDropdown" role="button" data-bs-toggle="dropdown">
                        Обучение
                    </a>
                    <ul class="dropdown-menu border-0 shadow-sm animate__animated animate__fadeIn">
                        <li><NavLink class="dropdown-item" href="lectures">Все лекции</NavLink></li>
                        <li><NavLink class="dropdown-item" href="recommended">Рекомендовано вам</NavLink></li>
                    </ul>
                </li>

                <AuthorizeView Roles="Admin, Specialist">
                    <li class="nav-item">
                        <NavLink class="nav-link text-manage" href="admin/lectures">Управление</NavLink>
                    </li>
                </AuthorizeView>
            </ul>

            <div class="d-flex align-items-center">
                <AuthorizeView>
                    <Authorized>
                        <div class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle profile-btn rounded-pill px-3" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle me-1"></i> @context.User.Identity?.Name
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end border-0 shadow-sm">
                                <li><NavLink class="dropdown-item" href="Account/Manage">Профиль</NavLink></li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form action="Account/Logout" method="post">
                                        <AntiforgeryToken />
                                        <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                                        <button type="submit" class="dropdown-item text-danger">Выйти</button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    </Authorized>
                    <NotAuthorized>
                        <NavLink class="btn btn-login rounded-pill me-2" href="Account/Login">Вход</NavLink>
                        <NavLink class="btn btn-register rounded-pill" href="Account/Register">Регистрация</NavLink>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>
    </div>
</nav>

@code {
    private string? currentUrl;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose() => NavigationManager.LocationChanged -= OnLocationChanged;
}