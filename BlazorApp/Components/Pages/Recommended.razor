@page "/recommended"
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@using BlazorApp.Shared.Models
@using BlazorApp.Shared.Interfaces
@attribute [Authorize]
@inject IChildService ChildService
@inject ILectureService LectureService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Рекомендации</PageTitle>

<h3>Рекомендованные лекции</h3>
<p class="text-muted">Подобрано специально на основе профилей ваших детей</p>

@if (recommendedLectures == null)
{
    <div class="spinner-border" role="status"></div>
}
else if (!recommendedLectures.Any())
{
    <div class="alert alert-info">
        Добавьте данные о детях и их особенностях в профиле, чтобы мы могли подобрать полезные материалы.
    </div>
}
else
{
    <div class="row">
        @foreach (var lecture in recommendedLectures)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <span class="badge bg-primary mb-2">@lecture.TargetDiagnosis</span>
                        <h5 class="card-title">@lecture.Title</h5>
                        <p class="card-text text-truncate">@lecture.Description</p>
                    </div>
                    <div class="card-footer bg-transparent border-top-0">
                        <button class="btn btn-primary w-100">Смотреть видео</button>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<Lecture>? recommendedLectures;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (userId != null)
        {
            var children = await ChildService.GetChildrenByParentIdAsync(userId);

            if (children != null && children.Any())
            {
                var diagnoses = children
                    .Select(c => c.Diagnosis.Trim().ToLower())
                    .Distinct()
                    .ToList();

                var allLectures = await LectureService.GetAllLecturesAsync();

                recommendedLectures = allLectures
                    .Where(l => diagnoses.Any(d => l.TargetDiagnosis.ToLower().Contains(d)))
                    .ToList();
            }
            else
            {
                recommendedLectures = new List<Lecture>();
            }
        }
    }
}