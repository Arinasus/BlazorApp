@page "/admin/lectures"
@using Microsoft.AspNetCore.Authorization
@using BlazorApp.Shared.Models
@using BlazorApp.Shared.Interfaces
@attribute [Authorize(Roles = "Admin, Specialist")]
@inject ILectureService LectureService

<div class="container mt-4">
    <h3>Управление базой знаний</h3>

    <div class="card mb-4 shadow-sm">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Добавить новую лекцию</h5>
        </div>
        <div class="card-body">
            <EditForm Model="newLecture" OnValidSubmit="HandleAddLecture">
                <DataAnnotationsValidator />
                
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label>Название лекции:</label>
                        <InputText @bind-Value="newLecture.Title" class="form-control" placeholder="Напр: Развитие речи у детей" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label>Целевой диагноз (тег для рекомендаций):</label>
                        <InputText @bind-Value="newLecture.TargetDiagnosis" class="form-control" placeholder="Напр: Дислексия" />
                    </div>
                </div>

                <div class="mb-3">
                    <label>Описание:</label>
                    <InputTextArea @bind-Value="newLecture.Description" class="form-control" rows="3" />
                </div>

                <div class="mb-3">
                    <label>Ссылка на видео (YouTube/URL):</label>
                    <InputText @bind-Value="newLecture.VideoUrl" class="form-control" />
                </div>

                <button type="submit" class="btn btn-success">Добавить в базу</button>
            </EditForm>
        </div>
    </div>

    <h4>Все лекции в системе</h4>
    <div class="table-responsive">
        <table class="table table-hover mt-3">
            <thead class="table-light">
                <tr>
                    <th>Название</th>
                    <th>Диагноз</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @if (allLectures != null)
                {
                    @foreach (var lecture in allLectures)
                    {
                        <tr>
                            <td>@lecture.Title</td>
                            <td><span class="badge bg-secondary">@lecture.TargetDiagnosis</span></td>
                            <td>
                                <button class="btn btn-sm btn-outline-danger">Удалить</button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private Lecture newLecture = new();
    private List<Lecture>? allLectures;

    protected override async Task OnInitializedAsync()
    {
        await LoadLectures();
    }

    private async Task LoadLectures()
    {
        allLectures = await LectureService.GetAllLecturesAsync();
    }

    private async Task HandleAddLecture()
    {
       
        await LectureService.AddLectureAsync(newLecture);
        newLecture = new(); 
        await LoadLectures(); 
    }
}